<!DOCTYPE html>
<html lang="en">
    
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="author" content="c.m.crews">
  <meta name="description" content="artist portfolio of current and previous work.">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Antic+Didone&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/x-icon" href="./images/favicon.png">

  <title>home - c.m.crews</title>

  <style>
    /* ===== HERO SECTION ===== */
    .hero-section {
      min-height: 80vh;
      display: flex;
      align-items: center;
      padding: 4rem 0;
    }

    .hero-text {
      font-family: 'Antic Didone', serif;
      font-size: 4rem;
      font-weight: 400;
      line-height: 1.3;
      color: #000;
      max-width: 950px;
      padding-top: 40px;
    }

    .hero-description {
      font-size: 16.5px;
      margin-top: 2rem;
      line-height: 1.7;
      color: #333;
    }

    /* ===== CV SECTION ===== */
    .cv-section {
      padding: 4rem 2rem;
      border-top: 0.7px solid rgba(112, 128, 144, 0.5);
    }

    .cv-content {
      max-width: 1050px;
      margin: 0 auto;
      text-align: right;
    }

    .cv-item {
      margin-bottom: 1.5rem;
      line-height: 1.7;
    }

    .cv-item-title {
      font-weight: 600;
      color: #000;
    }

    .cv-item-detail {
      color: #333;
      font-style: italic;
    }

    .cv-item-description {
      color: #333;
      margin-top: 0.3rem;
      font-size: 14px;
    }

    /* Links styling */
    .cv-link {
      display: block;
      margin-top: 1rem;
    }

    .cv-link a {
      color: var(--color-secondary);
      font-size: 16px;
      font-weight: 300;
      text-decoration: underline;
      text-underline-offset: 4px;
      text-decoration-thickness: 0.7px;
      transition: color var(--transition-default), font-weight var(--transition-default);
    }

    .cv-link a:hover {
      color: var(--color-accent);
      font-weight: 500;
    }

    @media (min-width: 769px) and (max-width: 1024px) {
      .hero-section {
        min-height: 70vh; /* Between desktop and mobile */
        padding: 3.5rem 2rem; /* Adjust spacing */
      }

      .cv-section {
        padding: 3.5rem 2rem; /* Match hero padding */
      }

      .cv-content {
        padding-right: 2rem;
      }
    }

    /* ===== MOBILE STYLES ===== */
    @media (max-width: 768px) {
      .hero-text {
        font-size: 2rem;
      }

      .hero-section {
        min-height: 60vh;
        padding: 3rem 1.5rem;
      }

      .cv-section {
        padding: 3rem 1.5rem;
      }

      .cv-content {
        text-align: center; /* Center CV on mobile */
      }
    }
  </style>
</head>

<body>
  <div class="navbar navbar-expand-lg">
    <%- include('header'); %>
  </div>

  <main>
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="container">
        <p class="hero-text">
          Multi-disciplinary artist working in the spaces between structure and interpretation.
        </p>
        <p class="hero-description">
          I'm interested in pattern-making systems—whether that's through fiber, generative algorithms, or the structures that emerge when you follow a set of rules. My background in art history and museums shows up in how I think about making things, but mostly I'm exploring what happens when you treat randomness and structure as raw materials. Based in Portland, OR.
        </p>
      </div>
    </section>

    <!-- CV Section -->
    <section class="cv-section">
      <div class="cv-content">
        <div class="cv-item">
          <div class="cv-item-title">Master of Arts in Creative Technology</div>
          <div class="cv-item-detail">Southern Methodist University</div>
          <div class="cv-item-detail">Dallas, TX</div>
        </div>

        <div class="cv-item">
          <div class="cv-item-title">Bachelor of Arts in Art History, Modern Art</div>
          <div class="cv-item-detail">California State University, Long Beach</div>
          <div class="cv-item-detail">Long Beach, CA</div>
        </div>

        <!-- <div class="cv-link">
          <a href="https://www.etsy.com/shop/YourShopName" target="_blank">shop</a>
        </div> -->
      </div>
    </section>
  </main>

  <footer>
    <%- include('footer'); %>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>

</html>